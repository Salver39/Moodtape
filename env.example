# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI GPT-4o Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.5

# Spotify API Configuration
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# Apple Music API Configuration (optional)
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=path/to/your/AuthKey.p8

# Database Configuration
DATABASE_URL=sqlite:///data/moodtape.db

# Logging Configuration
LOG_LEVEL=INFO

# Application Settings
DEFAULT_PLAYLIST_LENGTH=20
MAX_PLAYLIST_LENGTH=50
MAX_REQUESTS_PER_USER_PER_HOUR=10

# Feature Flags
ENABLE_SPOTIFY=true
ENABLE_APPLE_MUSIC=false
ENABLE_FEEDBACK=true

# Development Settings
DEBUG=false
WEBHOOK_URL=

# Instructions:
# 1. Copy this file to .env: cp env.example .env
# 2. Fill in your actual API keys and tokens
# 3. For Telegram bot token: contact @BotFather on Telegram
# 4. For OpenAI API key: visit https://platform.openai.com/api-keys
# 5. For Spotify API: visit https://developer.spotify.com/dashboard
# 6. For Apple Music API: visit https://developer.apple.com/music/ 